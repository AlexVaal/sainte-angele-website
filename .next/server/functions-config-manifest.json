{
  "version": 1,
  "functions": {
    "/_middleware": {
      "runtime": "nodejs",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?(?:\\/(\\/?index|\\/?index\\.json))?[\\/#\\?]?$",
          "originalSource": "/"
        },
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?\\/fr\\/location-de-salle(\\.json)?[\\/#\\?]?$",
          "originalSource": "/fr/location-de-salle"
        },
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?\\/fr\\/hall-rental(\\.json)?[\\/#\\?]?$",
          "originalSource": "/fr/hall-rental"
        }
      ]
    }
  }
}
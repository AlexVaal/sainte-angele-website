    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/hall-rental/layout,_N_T_/[lang]/hall-rental/page,_N_T_/en/hall-rental"
  },
  "segmentPaths": [

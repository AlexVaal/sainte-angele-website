{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/volunteer/layout,_N_T_/[lang]/volunteer/page,_N_T_/en/volunteer"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/volunteer/__PAGE__",
    "/$d$lang/volunteer",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}
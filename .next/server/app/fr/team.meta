{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/team/layout,_N_T_/[lang]/team/page,_N_T_/fr/team"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/team/__PAGE__",
    "/$d$lang/team",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}
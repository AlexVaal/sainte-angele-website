{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/donate/layout,_N_T_/[lang]/donate/page,_N_T_/fr/donate"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/donate/__PAGE__",
    "/$d$lang/donate",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}
{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/sermons/layout,_N_T_/[lang]/sermons/page,_N_T_/fr/sermons"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/sermons/__PAGE__",
    "/$d$lang/sermons",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}
{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/events/layout,_N_T_/[lang]/events/page,_N_T_/it/events"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/events/__PAGE__",
    "/$d$lang/events",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}